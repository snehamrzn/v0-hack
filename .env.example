# Copy to .env.local and fill in. .env.local is gitignored.
# These keys are used by the /api/chat and /api/mcp serverless functions —
# they stay server-side and are never sent to the browser.

ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for the Skill Registry MCP server (api/mcp/[transport].ts).
# A token with NO scopes is fine — it only hits public code search. Without
# one, search_skills falls back to unauthenticated requests (rate-limited to
# 10/min). Generate one at https://github.com/settings/tokens (classic) and
# leave all checkboxes unchecked.
GITHUB_TOKEN=

# Optional override for the MCP server URL. Defaults to same-origin
# (auto-detected from request headers in dev, VERCEL_URL in prod). Point at
# an external Skill Registry MCP if you want to test against a different one.
# MCP_URL=http://localhost:5173/api/mcp/mcp

# Redis-backed storage for shared skills (api/share.ts + api/skill.ts).
# Without these, share storage falls back to in-memory only — fine for dev
# but loses data on every cold start in prod. Set EITHER pair:
#
#   - Vercel KV defaults:
#     KV_REST_API_URL=https://...
#     KV_REST_API_TOKEN=...
#
#   - OR Upstash Redis directly:
#     UPSTASH_REDIS_REST_URL=https://...
#     UPSTASH_REDIS_REST_TOKEN=...
#
# (Vercel KV is Upstash under the hood; the two conventions are interchangeable.)
